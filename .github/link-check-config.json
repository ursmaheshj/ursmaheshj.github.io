{
  "ignorePatterns": [
    {
      "pattern": "^#"
    },
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "example\\.com"
    },
    {
      "pattern": "via\\.placeholder\\.com"
    },
    {
      "pattern": "localhost"
    },
    {
      "pattern": "127\\.0\\.0\\.1"
    }
  ],
  "httpHeaders": [
    {
      "urls": ["https://fonts.googleapis.com/"],
      "headers": {
        "Accept": "text/html"
      }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 299, 301, 302, 307, 308]
}
